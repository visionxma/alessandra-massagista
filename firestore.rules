rules_version = '2';

// =====================================================================
// Regras de seguranca - Agenda Alessandra
//
// Principio: o visitante do site pode PEDIR um horario, mas nunca
// enxergar dados de outros clientes. So a Alessandra (autenticada)
// le e gerencia a agenda.
//
// Cole em: Firebase Console > Firestore Database > Regras > Publicar
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function autenticada() {
      return request.auth != null;
    }

    function campos() {
      return request.resource.data;
    }

    // -----------------------------------------------------------------
    // servicos: qualquer um le (o site monta a lista), so a dona altera
    // -----------------------------------------------------------------
    match /servicos/{id} {
      allow read: if true;
      allow write: if autenticada();
    }

    // -----------------------------------------------------------------
    // configuracao: horario de funcionamento, lido pelo site
    // -----------------------------------------------------------------
    match /configuracao/{id} {
      allow read: if true;
      allow write: if autenticada();
    }

    // -----------------------------------------------------------------
    // agendamentos
    //   - visitante: SO cria, e apenas com status pendente e origem site.
    //     Nao pode ler, editar nem apagar nada.
    //   - Alessandra: acesso total.
    // -----------------------------------------------------------------
    match /agendamentos/{id} {
      // Dados pessoais: SO a profissional autenticada le, edita e apaga.
      // O visitante nunca acessa esta colecao; para saber quais horarios
      // estao tomados ele usa a colecao anonima /ocupados.
      allow read, update, delete: if autenticada();

      allow create: if autenticada() || (
           campos().status == 'pendente'
        && campos().origem == 'site'
        && campos().clienteNome is string
        && campos().clienteNome.size() >= 2
        && campos().clienteNome.size() <= 80
        && campos().servicoNome is string
        // telefone obrigatorio: 10 ou 11 digitos, com a mascara vira 14-16 chars
        && campos().clienteContato is string
        && campos().clienteContato.size() >= 10
        && campos().clienteContato.size() <= 20
        && campos().inicio is timestamp
        && campos().fim is timestamp
        && campos().inicio < campos().fim
        // impede agendar no passado
        && campos().inicio > request.time
        // teto de 90 dias no futuro, evita lixo na agenda
        && campos().inicio < request.time + duration.value(90, 'd')
        && (!('observacoes' in campos()) || campos().observacoes.size() <= 500)
      );
    }

    // -----------------------------------------------------------------
    // ocupados: espelho publico e ANONIMO dos horarios tomados.
    //
    // Guarda exclusivamente inicio e fim. Nenhum nome, telefone ou
    // observacao chega aqui, entao a leitura publica nao expoe dado
    // pessoal nenhum. E o que a pagina de agendamento consulta para
    // montar a grade e o que a transacao usa para impedir overbooking.
    // -----------------------------------------------------------------
    match /ocupados/{id} {
      allow read: if true;

      // o visitante so pode criar o marcador junto do seu agendamento,
      // e apenas com os dois campos de horario
      allow create: if autenticada() || (
           request.resource.data.keys().hasOnly(['inicio', 'fim'])
        && request.resource.data.inicio is timestamp
        && request.resource.data.fim is timestamp
        && request.resource.data.inicio < request.resource.data.fim
        && request.resource.data.inicio > request.time
      );

      // alterar ou liberar horario e coisa da profissional
      allow update, delete: if autenticada();
    }

    // -----------------------------------------------------------------
    // bloqueios: folgas e compromissos.
    //
    // A pagina publica precisa saber QUANDO nao ha atendimento, mas o
    // MOTIVO e assunto particular da profissional. Por isso o motivo
    // vive em /bloqueiosPrivados, de leitura restrita.
    // -----------------------------------------------------------------
    match /bloqueios/{id} {
      allow read: if true;
      allow write: if autenticada();
    }

    match /bloqueiosPrivados/{id} {
      allow read, write: if autenticada();
    }

    // Nega tudo que nao foi declarado acima
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
